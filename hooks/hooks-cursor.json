{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "./hooks/session-context"
      }
    ],
    "preToolUse": [
      {
        "matcher": { "tool": "Bash" },
        "command": "./hooks/check-bash"
      },
      {
        "matcher": { "tool": "Write" },
        "command": "./hooks/check-write"
      },
      {
        "matcher": { "tool": "Edit" },
        "command": "./hooks/check-write"
      }
    ]
  }
}
