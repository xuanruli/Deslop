#!/usr/bin/env bash
# Deslop PreToolUse(Write): 拦写入顶层垃圾目录（utils/helpers/common/misc/shared/lib）。

set -euo pipefail

input=$(cat)

file_path=$(printf '%s' "$input" | python3 -c "import json,sys; d=json.load(sys.stdin); print(d.get('tool_input',{}).get('file_path',''))" 2>/dev/null || echo "")
tool_name=$(printf '%s' "$input" | python3 -c "import json,sys; d=json.load(sys.stdin); print(d.get('tool_name',''))" 2>/dev/null || echo "")

if [ -z "$file_path" ]; then
  exit 0
fi

emit_block() {
  reason="$1"
  printf '{"decision":"block","reason":%s}\n' \
    "$(printf '%s' "$reason" | python3 -c "import json,sys; print(json.dumps(sys.stdin.read()))")"
  exit 0
}

repo_root=$(git -C "$(dirname "$file_path")" rev-parse --show-toplevel 2>/dev/null || pwd)

abs_path=$(python3 -c "import os,sys; print(os.path.abspath(sys.argv[1]))" "$file_path")
rel_path=${abs_path#"$repo_root"/}

top_segment=$(printf '%s' "$rel_path" | awk -F/ '{print $1}')

case "$top_segment" in
  utils|helpers|common|misc|shared|lib)
    if [ "$tool_name" = "Write" ]; then
      emit_block "Deslop 偏好：顶层目录 ${top_segment}/ 是垃圾桶式命名。
规则来自 project-structure 原则 1 + naming-principles 反模式 #1。
请按领域 / 概念命名（如 auth/、payments/、scheduler/、realtime/）。
子包内部小作用域 ${top_segment} 可以接受（src/auth/${top_segment}.ts），只禁顶层。
若坚持要写入此路径，请在用户确认后重试。"
    fi
    ;;
esac

exit 0
